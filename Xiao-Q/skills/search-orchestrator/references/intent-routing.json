  "depth_strategies": {
    "chain": {
      "description": "链条式深挖 — 从一个结果引出下一个相关搜索",
      "convergence_check": "连续2轮无新关联"
    },
    "timeline": {
      "description": "时间线追踪 — 按时间顺序追溯事件发展",
      "convergence_check": "时间线无断点"
    },
    "entity_drill": {
      "description": "实体深挖 — 对结果中出现的重要实体进行定向搜索",
      "convergence_check": "本轮产出新实体数为0"
    },
    "doc_trace": {
      "description": "文档链追踪 — 从文档/issue追踪到源码/修复",
      "convergence_check": "链断裂或无新文档"
    },
    "cross_verify": {
      "description": "交叉验证 — 对每个关键声明寻找独立来源",
      "convergence_check": "所有声明均已≥2源验证"
    },
    "dimension_table": {
      "description": "维度对比 — 按维度逐项对比并验证",
      "convergence_check": "所有对比维度已填充"
    }
  },

  "tool_matching_rules": {
    "version": "4.0 — 全量纳入体系",
    "how": "先排序，后全收。preferred_tools 仅决定调用顺序（靠前的先发），但不决定是否调用——任何 ready 的搜索工具最终都会被纳入。",
    "philosophy": "discover.js 是唯一的真相来源。它能发现什么，就调用什么。preferred_tools 是经验建议（排在前面的通常更有效），但不是准入过滤器。用户安装的任何新搜索 Skill 在被 discover.js 发现后立即生效，零配置介入。",
    "priority": [
      "1. preferred_tools 中所有 status=ready 的工具 → 纳入主工具集（优先排序，先调用）",
      "2. 剩余 ready 工具中，strengths/depth/coverage 与 required + supplementary capabilities 有任何交集的 → 纳入补充工具集",
      "3. 【关键】遍历 discover.js 返回的全部 ready 工具 → 尚未纳入的所有搜索/信息获取类工具 → 全部追加（零遗漏）",
      "4. 唯一排除：纯地理工具（仅有 geographic 标签）在非地理意图时可跳过",
      "5. 最终工具列表 = 主集 ∪ 补充集 ∪ 自动发现集，全部并行执行",
      "6. 0 个 ready → 告知用户 → 降级为 web_fetch 定向抓取"
    ],
    "auto_discovery": "用户安装新搜索 Skill 后：1) discover.js 下次运行时自动发现 2) search_orchestrator_catch_all 规则自动纳入 3) 无需编辑此文件。真正的零配置搜索聚合。",
    "strength_match": "工具的 strengths 与能力需求的交集用于排序（前=优先级高），不影响是否纳入",
    "cross_language": "语言标签（chinese/english）为偏好提示，非硬性过滤。Tavily 搜中文内容、Baidu 搜英文解读都是合法用法。"
  }
}
