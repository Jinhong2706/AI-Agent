{
  "version": "4.0.0",
  "description": "查询意图 → 偏好排序 → 全量纳入。preferred_tools 仅影响调用优先级而非是否纳入。discover.js 发现的每一个 ready 搜索工具都会被自动调用，无需手动修改此文件适配新工具。",

  "how_it_works": "1) discover.js 扫描全部可用工具 2) 意图分类确定偏好排序 3) preferred_tools 优先纳入 4) supplementary 匹配补充 5) 最终——所有 discover 发现的 ready 搜索工具全部并行调用，已知未知都不遗漏。装了新 skill 自动生效。",

  "search_orchestrator_catch_all": {
    "enabled": true,
    "rule": "完成 preferred + supplementary 匹配后，遍历 discover.js 返回的全部 ready 工具，将尚未被纳入的任何搜索/信息获取类工具全部追加到最终调用列表。唯一排除条件：纯地理工具（geographic标签）仅在非地理意图时可跳过。",
    "rationale": "不依赖人工维护的工具白名单。用户安装的任何搜索 Skill 都会被 discover.js 发现，然后被此规则自动纳入，无需修改 intent-routing.json。"
  },

  "intents": [
    {
      "intent": "geographic",
      "triggers": ["路线", "导航", "周边", "附近", "POI", "地图", "旅游规划", "热力图", "在哪", "怎么走", "距离", "地址", "方向", "查找地点"],
      "required_capabilities": {
        "strengths": ["geographic"],
        "min_sources": 1
      },
      "preferred_tools": ["amap-lbs-skill", "amap-lbs"],
      "supplementary_capabilities": {
        "strengths": ["chinese", "general", "news", "deep_research", "ai_optimized"],
        "coverage": ["china", "global"]
      },
      "depth_strategy": "chain",
      "max_rounds": 3,
      "note": "地图工具为主 + 所有其他搜索工具补充"
    },

    {
