      "triggers": [],
      "required_capabilities": {
        "min_sources": 2
      },
      "preferred_tools": ["web_search"],
      "supplementary_capabilities": {
        "strengths": ["chinese", "english", "general", "news", "deep_research", "ai_optimized", "dynamic_pages", "china_coverage", "deep_extract"],
