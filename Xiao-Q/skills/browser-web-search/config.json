{
  "name": "browser-web-search",
  "version": "0.4.3",
  "requiredEnvVars": [],
  "requires": {
    "runtime": {
      "node": ">=18.0.0"
    },
    "binaries": ["openclaw"],
    "packages": {
      "npm": "browser-web-search@0.4.3"
    }
  },
  "skill": {
    "name": "browser-web-search",
    "version": "0.4.3",
    "enabled": true,
    "autoInvoke": false
  },
  "commands": {
    "list": {
      "script": "./scripts/run.js",
      "args": ["list"],
      "description": "列出所有可用 adapter"
    },
    "search": {
      "script": "./scripts/run.js",
      "args": ["search"],
      "description": "搜索 adapter"
    },
    "info": {
      "script": "./scripts/run.js",
      "args": ["info"],
      "description": "查看 adapter 详情"
    },
    "run": {
      "script": "./scripts/run.js",
      "args": ["run"],
      "description": "运行 adapter"
    },
    "help": {
      "script": "./scripts/postinstall.js",
      "args": [],
      "description": "显示使用帮助"
    }
  },
  "environment": {
    "required": [
      "NODE_VERSION>=18.0.0"
    ],
    "optional": []
  },
  "install": {
    "type": "npm-global",
    "package": "browser-web-search",
    "version": "0.4.3",
    "command": "npm install -g browser-web-search@0.4.3",
    "binary": "bws",
    "global": true,
    "autoInstall": false,
    "autoUpdate": false,
    "riskLevel": "medium",
    "riskReason": "通过 npm 全局安装第三方包，该包会在浏览器页面上下文中执行 JavaScript。安装前请审计源码。",
    "requiresApproval": true,
    "source": {
      "type": "npm",
      "registry": "https://registry.npmjs.org",
      "package": "browser-web-search",
      "repository": "https://github.com/sipingme/browser-web-search",
      "license": "MIT",
      "audit": "https://github.com/sipingme/browser-web-search/blob/main/src/index.ts"
    },
    "verification": {
      "command": "node -e \"console.log(require(require('path').join(require('path').dirname(process.execPath),'..','lib','node_modules','browser-web-search','package.json')).version)\"",
      "expectedOutput": "0.4.3"
    }
  },
  "dependencies": {
    "npm": [
      "browser-web-search@0.4.3"
    ],
    "binaries": [
      "openclaw"
    ],
    "note": "Package is installed globally via npm and loaded in-process by the launcher (no subprocess). OpenClaw CLI is required by browser-web-search internally."
  },
  "permissions": {
    "filesystem": {
      "read": [],
      "write": ["~/.bws/"]
    },
    "network": {
      "domains": [
        "registry.npmjs.org",
        "*.npmjs.com",
        "*.zhihu.com",
        "*.xiaohongshu.com",
        "*.bilibili.com",
        "*.thepaper.cn",
        "*.qq.com",
        "*.163.com",
        "*.sina.com.cn",
        "*.weibo.com",
        "*.sogou.com",
        "*.weixin.qq.com",
        "*.toutiao.com",
        "*.36kr.com",
        "*.baidu.com",
        "*.bing.com",
        "*.google.com",
        "*.csdn.net",
        "*.cnblogs.com",
        "*.zhipin.com",
        "*.juejin.cn",
        "*.v2ex.com",
        "*.infoq.cn",
        "*.huxiu.com",
        "api-search.huxiu.com",
        "*.wallstreetcn.com",
        "api-one-wscn.awtmt.com",
        "*.xueqiu.com",
        "*.x.com",
        "*.twitter.com",
        "*.reddit.com",
        "*.ycombinator.com",
        "hn.algolia.com",
        "*.github.com",
        "api.github.com",
        "*.theverge.com",
        "*.arstechnica.com",
        "*.engadget.com",
        "*.douban.com",
        "*.eastmoney.com",
        "*.jike.ruguoapp.com",
        "*.hupu.com",
        "*.linkedin.com",
        "*.youtube.com",
        "*.googleapis.com",
        "*.arxiv.org",
        "*.bbc.com",
        "*.bbc.co.uk",
        "*.reuters.com",
        "*.dev.to",
        "*.stackoverflow.com",
        "*.pypi.org",
        "*.imdb.com",
        "*.genius.com",
        "*.gsmarena.com",
        "*.producthunt.com",
        "*.wikipedia.org",
        "*.openlibrary.org",
        "*.yahoo.com",
        "*.youdao.com",
        "*.smzdm.com",
        "*.qidian.com",
        "*.duckduckgo.com",
        "*.ctrip.com",
        "*.thehackernews.com",
        "*.duckduckgo.com"
      ],
      "note": "访问支持的平台域名，通过 OpenClaw 浏览器执行"
    },
    "browser": {
      "type": "openclaw",
      "access": [
        "当前页面 DOM",
        "当前页面 Session（继承登录态）",
        "站点 API 响应"
      ],
      "scope": "按 adapter 域名隔离"
    },
    "subprocess": {
      "declared": false,
      "note": "Launcher does not spawn subprocesses. The pinned npm package is loaded in-process via dynamic ESM import; see permissions.inProcessLoad."
    },
    "inProcessLoad": {
      "declared": true,
      "package": "browser-web-search",
      "loader": "dynamic ESM import (await import(file://...))",
      "sink": "scripts/run.js:safeRunBws (single call site)",
      "resolution": "platform-standard global node_modules roots only; require.resolve restricted to the same allow-list",
      "argvPolicy": "allow-listed subcommands & flags; length-bounded; control-char filtered; '--' delimited; injected via process.argv mutation",
      "justification": "In-process loader removes the exec sink from the skill repository while preserving argv validation and sensitivity-gating policy."
    }
  },
  "capabilities": {
    "sensitive": [
      {
        "type": "browser-session-access",
        "riskLevel": "high",
        "description": "通过 OpenClaw 在已认证的浏览器标签页中执行 JavaScript",
        "scope": "按 adapter 域名隔离（设计意图，非运行时强制）",
        "risks": [
          "第三方 npm 包在页面上下文中执行，可访问站点认证数据",
          "恶意或被篡改的包可能窃取 cookies、私信、收藏、订单等账户数据",
          "包代码不包含在此 Skill 中，需独立审计每个版本",
          "Launcher 无法阻止包内 JS 访问当前 OpenClaw 中其他已打开的标签"
        ],
        "mitigations": [
          "adapter 脚本开源可审计 (https://github.com/sipingme/browser-web-search)",
          "Launcher 对敏感 adapter 默认拒绝，需 BWS_ALLOW_SENSITIVE=1 或 --i-understand-sensitive 显式 opt-in",
          "BWS_PUBLIC_ONLY=1 硬隔离模式可拒绝所有敏感 adapter",
          "所有调用记录到 ~/.bws/audit.log（仅元数据）",
          "建议为 OpenClaw 使用独立浏览器 profile，不复用日常 profile",
          "建议 npm install 时加 --ignore-scripts 降低供应链注入面"
        ]
      }
    ],
    "policy": {
      "defaultForUnknownAdapter": "sensitive-deny",
      "sensitiveOptInEnv": "BWS_ALLOW_SENSITIVE",
      "sensitiveOptInFlag": "--i-understand-sensitive",
      "publicOnlyModeEnv": "BWS_PUBLIC_ONLY",
      "auditLog": "~/.bws/audit.log",
      "auditLogContent": "metadata-only (no payloads, no responses, args hashed via SHA-256)",
      "alwaysSensitiveSites": [
        "weixin", "xiaohongshu", "weibo", "xueqiu", "jike",
        "douban", "qidian", "ctrip", "x", "linkedin"
      ],
      "sensitiveCommandSuffixes": [
        "me", "feed", "history", "comments", "user_posts", "article"
      ],
      "publicSites": [
        "thepaper", "qqnews", "netease", "sina", "36kr", "huxiu",
        "wallstreetcn", "eastmoney", "juejin", "csdn", "cnblogs",
        "v2ex", "baidu", "hupu", "youdao", "smzdm", "infoq",
        "google", "bing", "duckduckgo", "github", "hn", "reddit",
        "bbc", "reuters", "verge", "ars", "engadget", "stackoverflow",
        "devto", "npm", "pypi", "arxiv", "imdb", "genius", "wikipedia",
        "openlibrary", "yahoo-finance", "gsmarena", "producthunt",
        "toutiao", "zhihu", "bilibili", "boss", "youtube"
      ]
    },
    "supplyChain": {
      "package": "browser-web-search@0.4.3",
      "registry": "https://registry.npmjs.org",
      "verifyCommand": "npm view browser-web-search@0.4.3 dist.integrity dist.shasum",
      "auditUrl": "https://github.com/sipingme/browser-web-search/blob/v0.4.3/src/index.ts",
      "recommendedInstallCommand": "npm install -g browser-web-search@0.4.3 --ignore-scripts",
      "policy": {
        "allowFloatingVersions": false,
        "requireAuditPerVersion": true,
        "preferredMirror": "internal-npm-registry-if-available"
      }
    },
    "privacyNotice": {
      "summary": "此 Skill 在你显式同意后会复用浏览器登录态，可读取你已登录站点的任何可见数据",
      "details": [
        "默认拒绝访问账户保护页面，需要 env 或 flag 显式 opt-in",
        "公开 adapter（hn/github/arxiv 等）无需登录态，调用风险较低",
        "敏感 adapter 调用会在 stderr 打印警告，并写入 ~/.bws/audit.log",
        "访问范围取决于你在目标站点的登录权限",
        "建议使用独立 OpenClaw 浏览器 profile，不要复用日常 profile"
      ]
    }
  }
}
