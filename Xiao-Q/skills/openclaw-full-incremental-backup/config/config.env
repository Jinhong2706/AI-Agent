# OpenClaw 备份系统配置文件模板
# ================================
# 此文件在安装时由 install.sh 自动生成到 <BACKUP_ROOT>/config.env
# 安装后可手动编辑，调整路径后下次备份自动生效
#
# =========================================

# OpenClaw 家目录（被备份的目录）
# 一般不需要修改，除非 OpenClaw 安装在其他位置
OPENCLAW_HOME="/root/.openclaw"

# 备份存储根目录
# 改为安装时指定的目录
BACKUP_ROOT="/mnt/data3/openclaw-backup"
