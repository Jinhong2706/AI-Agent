{
  "name": "self-improving",
  "version": "2.1.0",
  "schema_version": "1.0",
  "description": "通用自我反思+自我批评+自我学习记忆系统，为所有AI代理设计。通过三级存储（热/温/冷）从纠正、自我反思和模式观察中学习。",
  "author": "Claude Code",
  "created": "2026-01-01",
  "updated": "2026-05-25",
  "skill_type": "memory",
  "entry_point": "SKILL.md",
  "dependencies": [],
  "permissions": [],
  "input_schema": {
    "description": "记忆操作的输入模式",
    "user_input": {
      "type": "string",
      "required": false,
      "description": "记忆查询或操作的上下文"
    },
    "mode": {
      "type": "string",
      "required": false,
      "enum": ["query", "log", "promote", "archive", "stats", "export", "import", "setup"],
      "default": "query",
      "description": "操作模式：query(查询)|log(记录)|promote(晋升)|archive(归档)|stats(统计)|export(导出)|import(导入)|setup(设置)"
    },
    "target": {
      "type": "string",
      "required": false,
      "description": "目标记忆条目或模式"
    }
  },
  "applicable_scenarios": [
    "从用户纠错中学习",
    "任务完成后的自我改进",
    "跨会话模式检测",
    "AI代理记忆管理",
    "跨代理偏好共享"
  ],
  "key_features": {
    "memory_system": {
      "enabled": true,
      "description": "采用热层/温层/冷层架构的三级存储"
    },
    "correction_tracking": {
      "enabled": true,
      "description": "带计数跟踪的自动纠错记录"
    },
    "promotion_system": {
      "enabled": true,
      "description": "3次出现 → 确认 → 晋升到热层"
    },
    "overflow_handling": {
      "enabled": true,
      "description": "corrections-pending.md 用于溢出管理"
    },
    "heartbeat_maintenance": {
      "enabled": true,
      "description": "通过心跳进行自动化记忆维护"
    },
    "export_import": {
      "enabled": true,
      "description": "带备份的完整记忆导出/导入"
    }
  },
  "core_capabilities": [
    "完成工作后的自我反思",
    "从用户纠错中学习",
    "模式检测与晋升",
    "三级记忆存储（热层/温层/冷层）",
    "自动纠错溢出处理",
    "跨平台和跨代理兼容性"
  ],
  "output_sections": [
    "架构概述",
    "核心规则",
    "学习信号",
    "自我反思指南",
    "记忆操作",
    "安装指南",
    "安全边界",
    "术语表"
  ],
  "output_schema": {
    "description": "记忆操作的输出模式",
    "status": {
      "type": "string",
      "enum": ["success", "partial", "error"],
      "description": "操作状态：success(成功)|partial(部分成功)|error(错误)"
    },
    "mode": {"type": "string", "description": "执行的操作模式"},
    "entries_found": {"type": "number", "description": "找到的记忆条目数量"},
    "memory_stats": {
      "type": "object",
      "description": "内存统计信息",
      "properties": {
        "hot_lines": {"type": "number", "description": "热层当前行数"},
        "corrections_count": {"type": "number", "description": "纠错日志条目数量"},
        "pending_count": {"type": "number", "description": "待处理区条目数量"},
        "health": {"type": "string", "description": "健康状态：healthy|warning|critical"}
      }
    },
    "message": {"type": "string", "description": "操作结果说明信息"}
  },
  "compatibility": {
    "min_claude_code_version": "3.0",
    "platform": "all",
    "agents": ["claude_code", "codex", "copilot", "universal"],
    "os": ["linux", "darwin", "win32"]
  },
  "tags": [
    "self-improvement",
    "memory",
    "correction-tracking",
    "self-reflection",
    "pattern-detection",
    "跨平台",
    "自我学习"
  ],
  "license": "MIT",
  "distributable": true,
  "portable": true,
